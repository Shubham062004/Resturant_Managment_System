# Express Server
PORT=5000
NODE_ENV=development

# Authentication
JWT_SECRET=your_jwt_secret_should_be_long_and_secure_64_chars_min
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_should_be_long_and_secure_64_chars_min
JWT_REFRESH_EXPIRES_IN=7d

# Database Connections
# PostgreSQL (Used by Prisma)
DATABASE_URL="postgresql://admin:admin_password_9922@localhost:5432/abc?schema=public"

# MongoDB (Used by Mongoose)
MONGODB_URI="mongodb://localhost:27017/abc"
