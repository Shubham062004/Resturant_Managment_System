datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  phone                   String?                  @unique
  firstName               String
  lastName                String
  passwordHash            String?
  avatar                  String?
  role                    Role                     @default(CUSTOMER)
  organizationId          String?
  organization            Organization?            @relation(fields: [organizationId], references: [id])
  franchiseId             String?
  franchise               Franchise?               @relation(fields: [franchiseId], references: [id])
  isEmailVerified         Boolean                  @default(false)
  isPhoneVerified         Boolean                  @default(false)
  isActive                Boolean                  @default(true)
  orders                  Order[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  otps                    Otp[]
  reviews                 Review[]
  favorites               Favorite[]
  cart                    Cart?
  addresses               Address[]
  couponUsages            CouponUsage[]
  orderDrafts             OrderDraft[]
  kitchenOrders           KitchenOrder[]
  deliveryPartner         DeliveryPartner?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  
  // Auth Tracking
  otpEnabled              Boolean                  @default(false)
  lastLoginAt             DateTime?
  createdById             String?

  posOrders   POSOrder[]
  cashDrawers CashDrawer[]

  guestProfile    GuestProfile?
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]

  notifications          Notification[]
  notificationPreference NotificationPreference?
  recommendations        Recommendation[]
  customerSegment        CustomerSegment?

  // Operations Staff Fields
  salary                 Decimal?                 @db.Decimal(10, 2)
  attendanceCount        Int                      @default(0)
  performanceScore       Float                    @default(5.0)
  assignedCategory       String?

  inventoryRequests      InventoryRequest[]
}

enum Role {
  CUSTOMER
  CASHIER
  KITCHEN_STAFF
  HEAD_CHEF
  KITCHEN_MANAGER
  DELIVERY_PARTNER
  DELIVERY_MANAGER
  BRANCH_MANAGER
  OPERATIONS_MANAGER
  FINANCE_MANAGER
  ADMIN
  FRANCHISE_OWNER
  ORGANIZATION_OWNER
  SUPER_ADMIN
  INVENTORY_MANAGER
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  ownerId   String?  @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  restaurantGroups RestaurantGroup[]
  franchises       Franchise[]
  branches         Branch[]
  tenantSettings   TenantSettings?
}

model Franchise {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerName      String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users    User[]
  branches Branch[]
}

model TenantSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  settingsJson   String       @default("{}")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Otp {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String?
  phone     String?
  codeHash  String
  type      OtpType
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([email])
  @@index([phone])
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  LOGIN_2FA
  PASSWORD_RESET
}

model Table {
  id       String      @id @default(uuid())
  branchId String
  branch   Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  number   String      @unique
  capacity Int
  status   TableStatus @default(AVAILABLE)
  x        Float       @default(0.0)
  y        Float       @default(0.0)
  qrCode   String?     @unique
  active   Boolean     @default(true)

  reservations Reservation[]
  orders       Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
}

enum TableStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  BILLING
  CLEANING
  OUT_OF_SERVICE
}

model Reservation {
  id              String            @id @default(uuid())
  customerId      String
  customer        User              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branchId        String
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId         String?
  table           Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  reservationDate String // YYYY-MM-DD format
  reservationTime String // HH:mm format
  guestCount      Int
  specialRequest  String?
  status          ReservationStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([branchId])
  @@index([tableId])
  @@index([branchId, status])
  @@index([reservationDate, reservationTime])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

model WaitlistEntry {
  id                String         @id @default(uuid())
  customerId        String
  customer          User           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branchId          String
  branch            Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  guestCount        Int
  estimatedWaitTime Int // in minutes
  status            WaitlistStatus @default(WAITING)
  joinedAt          DateTime       @default(now())
  notifiedAt        DateTime?
  seatedAt          DateTime?
  cancelledAt       DateTime?

  @@index([branchId])
  @@index([customerId])
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  SEATED
  CANCELLED
  NO_SHOW
}

model GuestProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loyaltyPoints Int      @default(0)
  totalVisits   Int      @default(0)
  specialNotes  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id           String           @id @default(uuid())
  orderNumber  String           @unique @default(cuid())
  tableId      String?
  table        Table?           @relation(fields: [tableId], references: [id], onDelete: SetNull)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String?
  restaurant   RestaurantGroup? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  branchId     String?
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  addressId    String?
  address      Address?         @relation(fields: [addressId], references: [id], onDelete: SetNull)
  paymentId    String?
  payment      Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  subtotal    Decimal @db.Decimal(10, 2)
  tax         Decimal @db.Decimal(10, 2)
  deliveryFee Decimal @default(0.00) @db.Decimal(10, 2)
  discount    Decimal @default(0.00) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)

  status    OrderStatus @default(PLACED)
  orderType OrderType   @default(DINE_IN)
  notes     String?

  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  refunds            Refund[]
  bills              Bill[]
  kitchenOrder       KitchenOrder?
  deliveryAssignment DeliveryAssignment?
  driverEarnings     DriverEarnings?
  posOrder           POSOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([branchId])
  @@index([restaurantId])
  @@index([branchId, status])
  @@index([createdAt])
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
  READY_FOR_PICKUP
  PICKED_UP
}

enum OrderType {
  DINE_IN
  DELIVERY
  PICKUP
  WALK_IN
}

model OrderItem {
  id        String          @id @default(uuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int
  price     Decimal         @db.Decimal(10, 2)
}

model OrderStatusHistory {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus OrderStatus?
  newStatus OrderStatus
  changedBy String? // userId of whoever changed it
  timestamp DateTime     @default(now())
}

model Refund {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentId String?
  amount    Decimal      @db.Decimal(10, 2)
  reason    String?
  status    RefundStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

model Bill {
  id            String        @id @default(uuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subtotal      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0.00) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentStatus PaymentStatus @default(UNPAID)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_PAID
  REFUNDED
}

model RestaurantGroup {
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  type           String?       @default("DEFAULT")
  id             String        @id @default(uuid())
  name           String
  slug           String        @unique
  description    String?
  logo           String?
  coverImage     String?
  rating         Float         @default(0.0)
  status         String        @default("ACTIVE")
  branches       Branch[]
  categories     Category[]
  products       Product[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  Order          Order[]
}

model Branch {
  organizationId  String?
  organization    Organization?       @relation(fields: [organizationId], references: [id])
  franchiseId     String?
  franchise       Franchise?          @relation(fields: [franchiseId], references: [id])
  id              String              @id @default(uuid())
  restaurantId    String
  restaurant      RestaurantGroup     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name            String
  address         String
  city            String
  state           String
  latitude        Float
  longitude       Float
  openingTime     String
  closingTime     String
  deliveryRadius  Float
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  Order           Order[]
  inventory       Inventory[]
  purchaseOrders  PurchaseOrder[]
  stockMovements  StockMovement[]
  wasteRecords    WasteRecord[]
  inventoryAlerts InventoryAlert[]
  transfersOut    InventoryTransfer[] @relation("SourceBranch")
  transfersIn     InventoryTransfer[] @relation("DestinationBranch")
  terminals       POSTerminal[]
  tables          Table[]
  reservations    Reservation[]
  waitlistEntries WaitlistEntry[]
  settings        RestaurantSettings?
  inventoryRequests InventoryRequest[]

  @@index([restaurantId])
}

model RestaurantSettings {
  id               String   @id @default(uuid())
  branchId         String   @unique
  branch           Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  taxRate          Float    @default(0.0)
  deliveryFee      Float    @default(0.0)
  currency         String   @default("USD")
  autoAcceptOrders Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Category {
  id           String          @id @default(uuid())
  restaurantId String
  restaurant   RestaurantGroup @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  image        String?
  description  String?
  sortOrder    Int             @default(0)
  isActive     Boolean         @default(true)
  products     Product[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([restaurantId, slug])
  @@index([restaurantId])
}

model Product {
  id               String           @id @default(uuid())
  restaurantId     String
  restaurant       RestaurantGroup  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name             String
  slug             String
  description      String?
  shortDescription String?
  image            String?
  gallery          String[]
  basePrice        Decimal          @db.Decimal(10, 2)
  rating           Float            @default(0.0)
  calories         Int?
  preparationTime  Int?
  isVeg            Boolean          @default(false)
  isAvailable      Boolean          @default(true)
  featured         Boolean          @default(false)
  variants         ProductVariant[]
  reviews          Review[]
  favorites        Favorite[]
  cartItems        CartItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  OrderItem        OrderItem[]
  kitchenTasks     KitchenTask[]
  recipeMappings   RecipeMapping[]
  recommendations  Recommendation[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
  @@index([categoryId])
}

model ProductVariant {
  id        String      @id @default(uuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal     @db.Decimal(10, 2)
  stock     Int         @default(0)
  isDefault Boolean     @default(false)
  cartItems CartItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  OrderItem OrderItem[]

  @@index([productId])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String          @id @default(uuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int
  price     Decimal         @db.Decimal(10, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([cartId])
  @@index([productId])
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String   @default("India")
  postalCode   String
  latitude     Float?
  longitude    Float?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  Order        Order[]

  @@index([userId])
}

model Coupon {
  id            String        @id @default(uuid())
  code          String        @unique
  description   String?
  discountType  DiscountType
  discountValue Decimal       @db.Decimal(10, 2)
  minimumAmount Decimal       @default(0.00) @db.Decimal(10, 2)
  maxDiscount   Decimal?      @db.Decimal(10, 2)
  startDate     DateTime
  endDate       DateTime
  usageLimit    Int?
  usedCount     Int           @default(0)
  active        Boolean       @default(true)
  usages        CouponUsage[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
}

model CouponUsage {
  id       String   @id @default(uuid())
  couponId String
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usedAt   DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

model OrderDraft {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtotal    Decimal          @db.Decimal(10, 2)
  tax         Decimal          @db.Decimal(10, 2)
  deliveryFee Decimal          @db.Decimal(10, 2)
  discount    Decimal          @default(0.00) @db.Decimal(10, 2)
  totalAmount Decimal          @db.Decimal(10, 2)
  status      OrderDraftStatus @default(PENDING)
  payment     Payment?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

enum OrderDraftStatus {
  PENDING
  PAYMENT_FAILED
  COMPLETED
}

model Payment {
  id            String          @id @default(uuid())
  orderDraftId  String          @unique
  orderDraft    OrderDraft      @relation(fields: [orderDraftId], references: [id], onDelete: Cascade)
  provider      PaymentProvider
  transactionId String?         @unique
  amount        Decimal         @db.Decimal(10, 2)
  status        PaymentStatus   @default(UNPAID)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  Order         Order[]
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
}

// ----------------------------------------------------
// KITCHEN DISPLAY SYSTEM (KDS) MODELS
// ----------------------------------------------------

model KitchenStation {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  active      Boolean        @default(true)
  orders      KitchenOrder[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum KitchenOrderStatus {
  QUEUED
  COOKING
  READY_FOR_PACKING
  PACKED
  COMPLETED
}

enum KitchenPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model KitchenOrder {
  id           String             @id @default(uuid())
  orderId      String             @unique
  order        Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stationId    String?
  station      KitchenStation?    @relation(fields: [stationId], references: [id], onDelete: SetNull)
  assignedTo   String?
  assignedUser User?              @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  priority     KitchenPriority    @default(MEDIUM)
  status       KitchenOrderStatus @default(QUEUED)
  tasks        KitchenTask[]
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([orderId])
  @@index([stationId])
  @@index([assignedTo])
}

model KitchenTask {
  id             String       @id @default(uuid())
  kitchenOrderId String
  kitchenOrder   KitchenOrder @relation(fields: [kitchenOrderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity       Int
  notes          String?
  status         String       @default("PENDING") // PENDING, DONE
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([kitchenOrderId])
  @@index([productId])
}

// ----------------------------------------------------
// DELIVERY MANAGEMENT MODELS
// ----------------------------------------------------

model DeliveryPartner {
  id            String               @id @default(uuid())
  userId        String               @unique
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType   String
  vehicleNumber String
  licenseNumber String
  activeStatus  Boolean              @default(true)
  rating        Float                @default(0.0)
  assignments   DeliveryAssignment[]
  earnings      DriverEarnings[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

enum DeliveryStatus {
  ASSIGNED
  ACCEPTED
  AT_RESTAURANT
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

model DeliveryAssignment {
  id          String          @id @default(uuid())
  orderId     String          @unique
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driverId    String
  driver      DeliveryPartner @relation(fields: [driverId], references: [id], onDelete: Cascade)
  status      DeliveryStatus  @default(ASSIGNED)
  assignedAt  DateTime        @default(now())
  acceptedAt  DateTime?
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  proof       DeliveryProof?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([driverId])
}

model DeliveryProof {
  id           String             @id @default(uuid())
  assignmentId String             @unique
  assignment   DeliveryAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  imageUrl     String?
  signatureUrl String?
  notes        String?
  timestamp    DateTime           @default(now())
}

model DriverEarnings {
  id        String          @id @default(uuid())
  driverId  String
  driver    DeliveryPartner @relation(fields: [driverId], references: [id], onDelete: Cascade)
  orderId   String          @unique
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  earnings  Decimal         @db.Decimal(10, 2)
  bonus     Decimal         @default(0.00) @db.Decimal(10, 2)
  createdAt DateTime        @default(now())

  @@index([driverId])
}

// ----------------------------------------------------
// INVENTORY MANAGEMENT MODELS
// ----------------------------------------------------

model Ingredient {
  id           String   @id @default(uuid())
  name         String
  sku          String   @unique
  category     String
  unit         String // KG, Gram, Liter, ML, Piece, Pack
  minimumStock Float
  reorderPoint Float
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventory      Inventory[]
  purchaseItems  PurchaseOrderItem[]
  stockMovements StockMovement[]
  wasteRecords   WasteRecord[]
  recipeMappings RecipeMapping[]
  alerts         InventoryAlert[]
  transfers      InventoryTransfer[]
  inventoryRequestItems InventoryRequestItem[]
}

model Inventory {
  id                String     @id @default(uuid())
  ingredientId      String
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  branchId          String
  branch            Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quantity          Float      @default(0.0)
  reservedQuantity  Float      @default(0.0)
  availableQuantity Float      @default(0.0)
  lastUpdated       DateTime   @default(now())

  @@unique([ingredientId, branchId])
  @@index([branchId])
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  rating        Float    @default(0.0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  totalAmount Decimal             @db.Decimal(10, 2)
  status      PurchaseOrderStatus @default(DRAFT)
  orderedAt   DateTime            @default(now())
  receivedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@index([supplierId])
  @@index([branchId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  APPROVED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity        Float
  costPrice       Decimal       @db.Decimal(10, 2)

  @@index([purchaseOrderId])
}

model StockMovement {
  id           String            @id @default(uuid())
  ingredientId String
  ingredient   Ingredient        @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type         StockMovementType
  quantity     Float
  referenceId  String? // E.g. Order ID or PO ID
  notes        String?
  createdAt    DateTime          @default(now())

  @@index([ingredientId])
  @@index([branchId])
}

enum StockMovementType {
  PURCHASE
  CONSUMPTION
  WASTE
  TRANSFER
  ADJUSTMENT
}

model WasteRecord {
  id           String     @id @default(uuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quantity     Float
  reason       String
  recordedBy   String // User ID
  createdAt    DateTime   @default(now())

  @@index([ingredientId])
  @@index([branchId])
}

model InventoryTransfer {
  id                  String         @id @default(uuid())
  sourceBranchId      String
  sourceBranch        Branch         @relation("SourceBranch", fields: [sourceBranchId], references: [id], onDelete: Cascade)
  destinationBranchId String
  destinationBranch   Branch         @relation("DestinationBranch", fields: [destinationBranchId], references: [id], onDelete: Cascade)
  ingredientId        String
  ingredient          Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity            Float
  status              TransferStatus @default(PENDING)
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([sourceBranchId])
  @@index([destinationBranchId])
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model RecipeMapping {
  id               String     @id @default(uuid())
  productId        String
  product          Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredientId     String
  ingredient       Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantityRequired Float

  @@unique([productId, ingredientId])
  @@index([productId])
}

model InventoryAlert {
  id           String     @id @default(uuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  alertType    String // e.g. "LOW_STOCK", "OUT_OF_STOCK"
  status       String     @default("ACTIVE") // ACTIVE, RESOLVED
  createdAt    DateTime   @default(now())

  @@index([ingredientId])
  @@index([branchId])
}

// ----------------------------------------------------
// POINT OF SALE (POS) MODELS
// ----------------------------------------------------

model POSTerminal {
  id           String       @id @default(uuid())
  branchId     String
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  terminalName String
  active       Boolean      @default(true)
  orders       POSOrder[]
  cashDrawers  CashDrawer[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([branchId])
}

model POSOrder {
  id         String      @id @default(uuid())
  terminalId String
  terminal   POSTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  cashierId  String
  cashier    User        @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  orderId    String      @unique
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status   POSOrderStatus @default(OPEN)
  payments POSPayment[]
  receipt  Receipt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([terminalId])
  @@index([cashierId])
}

enum POSOrderStatus {
  OPEN
  PAID
  VOIDED
  REFUNDED
}

model POSPayment {
  id                   String           @id @default(uuid())
  posOrderId           String
  posOrder             POSOrder         @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  method               POSPaymentMethod
  amount               Decimal          @db.Decimal(10, 2)
  transactionReference String?
  status               POSPaymentStatus @default(COMPLETED)
  createdAt            DateTime         @default(now())

  @@index([posOrderId])
}

enum POSPaymentMethod {
  CASH
  UPI
  CARD
  WALLET
  SPLIT
}

enum POSPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Receipt {
  id            String   @id @default(uuid())
  posOrderId    String   @unique
  posOrder      POSOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)
  receiptNumber String   @unique
  generatedAt   DateTime @default(now())
}

model CashDrawer {
  id             String      @id @default(uuid())
  terminalId     String
  terminal       POSTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  cashierId      String
  cashier        User        @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  openingAmount  Decimal     @db.Decimal(10, 2)
  closingAmount  Decimal?    @db.Decimal(10, 2)
  currentBalance Decimal     @db.Decimal(10, 2)
  status         ShiftStatus @default(OPEN)
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  notes          String?

  @@index([terminalId])
  @@index([cashierId])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ---------------------------------------------------------------------
// NOTIFICATIONS & CAMPAIGNS
// ---------------------------------------------------------------------

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  channel     String
  title       String
  message     String    @db.Text
  status      String    @default("PENDING")
  priority    String    @default("NORMAL")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NotificationPreference {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled     Boolean  @default(true)
  smsEnabled       Boolean  @default(true)
  whatsappEnabled  Boolean  @default(false)
  pushEnabled      Boolean  @default(true)
  marketingEnabled Boolean  @default(false)
  quietHoursStart  String?
  quietHoursEnd    String?
  updatedAt        DateTime @updatedAt
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  eventType String
  subject   String?
  content   String   @db.Text
  channel   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id             String    @id @default(uuid())
  name           String
  type           String
  targetAudience String
  status         String    @default("DRAFT")
  scheduledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Recommendation {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  score       Float
  generatedAt DateTime @default(now())

  @@index([userId])
  @@index([productId])
}

model CustomerSegment {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  segment    String
  confidence Float
  updatedAt  DateTime @updatedAt
}

model AIInsight {
  id          String   @id @default(uuid())
  type        String
  title       String
  description String
  generatedAt DateTime @default(now())
}

// ----------------------------------------------------
// INVENTORY REQUESTS MODELS
// ----------------------------------------------------

model InventoryRequest {
  id             String                 @id @default(uuid())
  branchId       String
  branch         Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  status         InventoryRequestStatus @default(PENDING)
  requestedById  String
  requestedBy    User                   @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  notes          String?
  approvedAt     DateTime?
  dispatchedAt   DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  items          InventoryRequestItem[]
}

model InventoryRequestItem {
  id                 String           @id @default(uuid())
  requestId          String
  request            InventoryRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  ingredientId       String
  ingredient         Ingredient       @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  requestedQuantity  Float
  approvedQuantity   Float?
}

enum InventoryRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PACKED
  DISPATCHED
  DELIVERED
}
