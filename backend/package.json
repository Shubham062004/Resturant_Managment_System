{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate --schema src/database/schema.prisma && tsc",
    "start": "node dist/server.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "prisma:generate": "prisma generate --schema src/database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/database/schema.prisma",
    "seed:postgres": "ts-node-dev --transpile-only src/database/seed.postgres.ts",
    "seed:mongodb": "ts-node-dev --transpile-only src/database/seed.mongodb.ts",
    "seed": "ts-node-dev --transpile-only src/database/seed.ts",
    "seed:inventory": "ts-node-dev --transpile-only src/database/seed.inventory.ts",
    "seed:dummy-history": "ts-node-dev --transpile-only src/database/seeders/dummy-history-seeder.ts",
    "reset-demo": "prisma migrate reset --force --schema src/database/schema.prisma",
    "create-demo-data": "npm run reset-demo && npm run seed",
    "create-demo-environment": "npm run create-demo-data",
    "test": "vitest run"
  },
  "dependencies": {
    "@logtail/pino": "^0.5.8",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.56.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0"
  }
}
