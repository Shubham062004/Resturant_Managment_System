# --- GLOBAL CONFIGURATION ---
NODE_ENV=development
APP_NAME=Resturant

# --- BACKEND SERVER ---
PORT=5000
JWT_SECRET=your_jwt_secret_should_be_long_and_secure_64_chars_min
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_jwt_refresh_secret_should_be_long_and_secure_64_chars_min
JWT_REFRESH_EXPIRES_IN=7d

# --- DATABASES ---
# PostgreSQL Primary Database Configuration (via Prisma)
DATABASE_URL="postgresql://admin:admin_password_9922@localhost:5432/oven_xpress?schema=public"

# MongoDB Document Database Configuration (via Mongoose)
MONGODB_URI="mongodb://localhost:27017/oven_xpress"

# --- FRONTEND CLIENT ---
VITE_API_URL="http://localhost:5000"
